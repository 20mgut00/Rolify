# =========================================
# RPG CHARACTER CREATOR - Environment Variables
# =========================================
# Copia este archivo como .env y rellena con tus valores reales

# ===== MongoDB Configuration =====
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/
MONGODB_DATABASE=rpg-characters

# ===== JWT Security =====
JWT_SECRET=your-256-bit-secret-key-change-this-in-production

# ===== Google OAuth (Opcional) =====
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ===== Email Configuration =====
# Opción 1: Resend (Recomendado)
MAIL_HOST=smtp.resend.com
MAIL_PORT=587
MAIL_USERNAME=resend
MAIL_PASSWORD=re_your_api_key_here
EMAIL_FROM=noreply@yourdomain.com

# Opción 2: Gmail (Alternativa)
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password-here
# EMAIL_FROM=your-email@gmail.com

# Opción 3: SendGrid (Alternativa)
# MAIL_HOST=smtp.sendgrid.net
# MAIL_PORT=587
# MAIL_USERNAME=apikey
# MAIL_PASSWORD=your-sendgrid-api-key
# EMAIL_FROM=noreply@yourdomain.com

# ===== Frontend URL =====
FRONTEND_URL=http://localhost:5173
